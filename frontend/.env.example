# REST API — local dev defaults to /api (proxied to :5000 via package.json)
# REACT_APP_API_URL=/api
# Or explicit: REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_URL=

# Socket.IO server (LyceumSocket)
REACT_APP_SOCKET_URL=http://localhost:5001

# PeerJS signaling server (LyceumPeerServer)
REACT_APP_PEER_HOST=localhost
REACT_APP_PEER_PORT=9000

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# In Google Cloud Console → Credentials → your OAuth client, add:
#   Authorized JavaScript origins: http://localhost:3000
#   Authorized redirect URIs: http://localhost:5000/api/auth/google/callback
