# REST API
# Local dev: /api (proxied to :5000 via package.json)
# Production: https://lyceum.vercel.app/api (same-origin; vercel.json proxies to lyceum-server)
# If unset or still pointing at lyceum-server, the app auto-uses window.location.origin/api
REACT_APP_API_URL=https://lyceum.vercel.app/api

# Socket.IO server (LyceumSocket)
REACT_APP_SOCKET_URL=http://localhost:5001

# PeerJS signaling server (LyceumPeerServer)
REACT_APP_PEER_HOST=localhost
REACT_APP_PEER_PORT=9000

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Google Cloud Console → Credentials → OAuth client:
#   Authorized JavaScript origins:
#     - http://localhost:3000
#     - https://lyceum.vercel.app
#   Authorized redirect URIs (GIS redirect login_uri):
#     - http://localhost:5000/api/auth/google/callback  (local dev, direct to backend)
#     - https://lyceum.vercel.app/api/auth/google/callback  (production, via frontend proxy)
